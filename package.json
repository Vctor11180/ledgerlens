{
  "name": "ledgerlens-backend",
  "version": "1.0.0",
  "description": "Backend API for LedgerLens - Avalanche wallet analysis",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "genlayer:wallet": "node scripts/genlayer-wallet.js",
    "genlayer:check-wallet": "node scripts/check-wallet.js",
    "deploy:genlayer": "node scripts/deploy-genlayer.js",
    "validate": "node scripts/validate.js",
    "verify:genlayer": "node scripts/verify-genlayer.js",
    "validate:build": "cd ledgerlens-front && npm run build",
    "validate:full": "npm run validate:build && npm run validate",
    "dev:front": "cd ledgerlens-front && npm run dev"
  },
  "dependencies": {
    "@payai/facilitator": "^2.3.4",
    "@x402/core": "^2.7.0",
    "@x402/evm": "^2.7.0",
    "@x402/express": "^2.7.0",
    "@x402/fetch": "^2.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "genlayer-js": "^0.23.0",
    "openai": "^4.73.0",
    "viem": "^2.47.6"
  }
}
